<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FlightBookingSuite">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Positive Tests">
        <classes>
            <class name="tests.FlightBookingTest"/>
        </classes>
    </test>

    <test name="Negative Tests">
        <classes>
            <class name="tests.NegativeBookingTest"/>
            <class name="tests.InvalidPageValidationTest"/>
        </classes>
    </test>
</suite>