<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FlightBookingSuite">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Run Positive Tests Only">

        <groups>
            <run>
                <include name="positive"/>
            </run>
        </groups>

        <classes>
            <class name="tests.FlightBookingTest"/>
            <class name="tests.InvalidPageValidationTest"/>
        </classes>

    </test>

    
</suite>